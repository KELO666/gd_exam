# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-api-key
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3

# 数据库配置 (默认为本地 SQLite)
# 若部署云端，请使用 Turso 等 Serverless SQLite 服务
DATABASE_URL=file:./data/notices.db
DATABASE_AUTH_TOKEN=

# 邮件推送（可选）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=

# Serverless Cron 密钥
CRON_SECRET=your_super_secret_token_here
